DATABASE_URL=postgresql://postgres:password@localhost:5432/adp_db
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Termii SMS (https://termii.com) - Nigerian SMS provider
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=N-Alert

# VTPass API (https://vtpass.com) - Nigerian VTU provider
VTPASS_API_KEY=your-vtpass-api-key
VTPASS_SECRET_KEY=your-vtpass-secret-key
VTPASS_BASE_URL=https://sandbox.vtpass.com/api

# Dev mode - skip real SMS and VTU calls
DEV_MODE=true
TEST_OTP=123456
