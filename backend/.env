# ─────────────────────────────────────────────
# ADP Nigeria Backend — Environment Config
# ─────────────────────────────────────────────

# Set DEV_MODE=true  → SQLite (no installation needed, auto path: ./adp.db)
# Set DEV_MODE=false → PostgreSQL (set PG_* credentials below)
DEV_MODE=true

# ── Optional: override the auto-selected database URL ──
# DATABASE_URL=sqlite:///./adp.db
# DATABASE_URL=postgresql://postgres:password@localhost:5432/adp_db

# ── PostgreSQL credentials (used when DEV_MODE=false) ──
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=password
PG_DB=adp_db

# ── JWT ──
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Dev OTP ──
TEST_OTP=123456

# ── Third-party API keys (production) ──
TERMII_API_KEY=
TERMII_SENDER_ID=N-Alert
VTPASS_API_KEY=
VTPASS_SECRET_KEY=
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
